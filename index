    .vclear:hover{color:var(--text2);}
    .rempty{padding:2rem;text-align:center;color:var(--muted);font-size:.82rem;line-height:1.7;}
    .sbanner{display:flex;align-items:center;gap:.6rem;padding:.72rem 1rem;font-family:var(--fd);font-size:.78rem;font-weight:600;letter-spacing:.05em;border-bottom:1px solid var(--border);}
    .sbanner.ok{color:var(--green);background:rgba(0,224,138,.05);}
    .sbanner.bad{color:var(--red);background:rgba(255,68,85,.05);}
    .diag{padding:.7rem 1rem;border-bottom:1px solid var(--border);font-size:.78rem;}
    .diag:last-child{border-bottom:none;}
    .dlabel{font-size:.6rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:.45rem;}
    .kv2{display:flex;gap:.5rem;margin-bottom:.28rem;align-items:center;}
    .kv2:last-child{margin-bottom:0;}
    .kvk{font-family:var(--fm);font-size:.7rem;color:var(--text2);width:78px;flex-shrink:0;}
    .kvv{font-family:var(--fm);font-size:.76rem;color:var(--tl);flex:1;}
    .eline{font-family:var(--fm);font-size:.73rem;color:var(--red);background:rgba(255,68,85,.07);border-radius:5px;padding:.35rem .55rem;margin-bottom:4px;}
    .wline{font-family:var(--fm);font-size:.73rem;color:var(--gold);margin-bottom:4px;}
    .sbar{display:flex;gap:3px;flex-wrap:wrap;margin-top:.4rem;}
    .sn{width:29px;height:29px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:.58rem;font-weight:700;}
    .trow{display:flex;align-items:center;gap:.6rem;padding:.38rem 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:.77rem;cursor:pointer;}
    .trow:last-child{border-bottom:none;}
    .trow:hover .tname{color:var(--tl);}
    .tname{flex:1;color:var(--text2);}
    .tpass{font-family:var(--fm);font-size:.7rem;color:var(--green);}
    .tfail{font-family:var(--fm);font-size:.7rem;color:var(--red);}
    .tsum{font-family:var(--fm);font-size:.7rem;text-align:right;padding-top:.45rem;}

    /* Downloads */
    .dl-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1rem;}
    .dl-card{background:var(--elev);border:1px solid var(--border);border-radius:12px;padding:1.2rem;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;gap:.45rem;}
    .dl-card:hover{border-color:var(--tl);transform:translateY(-2px);}
    .dli{font-size:1.4rem;}
    .dln{font-family:var(--fd);font-size:.83rem;color:var(--gold);font-weight:600;}
    .dlt{font-family:var(--fm);font-size:.66rem;color:var(--tl);margin-top:auto;}

    /* Implementors */
    .icard{background:var(--elev);border:1px solid var(--border);border-radius:12px;padding:1.4rem;display:flex;align-items:center;gap:1.25rem;}
    .ilogo{width:46px;height:46px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;}
    .iname{font-family:var(--fd);font-size:.92rem;color:var(--text);font-weight:600;margin-bottom:.2rem;}
    .idesc{font-size:.8rem;color:var(--text2);}
    .ibadge{font-family:var(--fm);font-size:.66rem;padding:.12rem .4rem;border-radius:4px;margin-left:.4rem;background:rgba(0,128,128,.15);color:var(--tl);border:1px solid rgba(0,128,128,.3);}

    /* Footer */
    footer{background:var(--panel);border-top:2px solid var(--teal);padding:2.5rem 2rem;text-align:center;color:var(--muted);font-size:.78rem;line-height:2;}
    footer strong{color:var(--gold);}
    footer a{color:var(--text2);}
    footer a:hover{color:var(--gold);}

    @keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
    .fi{animation:fadeUp .35s ease forwards;}
    @media(max-width:600px){.nav-links{display:none;}section{padding:3rem 1.25rem;}.hero{padding:3rem 1.25rem 2.5rem;}}
  </style>
</head>
