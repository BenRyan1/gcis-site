<section>
  <div class="inner">
    <div class="slabel">Why</div>
    <h2 class="stitle">Music tools don't speak the same language.<br>GCIS changes that.</h2>
    <p class="sdesc">Every DAW, every theory app, every AI music generator has its own internal state. GCIS is the universal envelope that lets them share a harmonic context instantly.</p>
    <div class="why-grid">
      <div class="why-card"><div class="wi">🎯</div><div class="wt">Single Source of Truth</div><div class="wd">Root, mode, scale intervals, and active MIDI notes in one validated JSON envelope. No ambiguity, no drift.</div></div>
      <div class="why-card"><div class="wi">🔁</div><div class="wt">Portable Across Tools</div><div class="wd">Save a session in the KCM Console. Load it in Ableton, MuseScore, or any AI generator that reads GCIS. One click.</div></div>
      <div class="why-card"><div class="wi">🏫</div><div class="wt">Built for Education</div><div class="wd">Teachers save harmonic contexts as .gcis files. Students load them and immediately see and hear the same musical state.</div></div>
      <div class="why-card"><div class="wi">🤖</div><div class="wt">AI-Ready</div><div class="wd">GCIS gives AI music tools a structured harmonic prompt. "Generate in G Dorian" is now a file, not a guess.</div></div>
      <div class="why-card"><div class="wi">✅</div><div class="wt">Validated at Format Level</div><div class="wd">The spec enforces KCM modal vocabulary. "major" is not a mode. "H" is not a note. The validator catches it instantly.</div></div>
      <div class="why-card"><div class="wi">🔓</div><div class="wt">Human-Readable</div><div class="wd">Plain JSON. Open any .gcis file in a text editor and read it. Change the root by hand. Load it back. It just works.</div></div>
    </div>
  </div>
</section>

<section id="spec">
  <div class="inner">
    <div class="slabel">Specification</div>
    <h2 class="stitle">GCIS v1.0 — File Format Reference</h2>
    <p class="sdesc">A .gcis file is a UTF-8 encoded JSON document with a versioned envelope. The <code style="font-family:var(--fm);color:var(--tl)">state</code> object is the canonical harmonic snapshot.</p>
    <div class="spec-grid">
      <div class="spec-blk">
        <div class="spec-hd">Complete example — G Dorian</div>
        <pre id="ex-json"></pre>
      </div>
      <div class="spec-blk">
        <div class="spec-hd">Field reference</div>
        <table class="ftable">
          <thead><tr><th>Field</th><th>Type</th><th>Req</th><th>Description</th></tr></thead>
          <tbody>
            <tr><td class="fk">gcis</td><td class="ft">string</td><td class="fr">✅</td><td class="fd">Format version — always "1.0"</td></tr>
            <tr><td class="fk">state.root</td><td class="ft">string</td><td class="fr">✅</td><td class="fd">Pitch class — one of 12 valid values</td></tr>
            <tr><td class="fk">state.mode</td><td class="ft">string</td><td class="fr">✅</td><td class="fd">Modal name — one of 7 valid values</td></tr>
            <tr><td class="fk">state.scale</td><td class="ft">int[]</td><td class="fr">✅</td><td class="fd">7 semitone intervals from root</td></tr>
            <tr><td class="fk">state.activeNotes</td><td class="ft">int[]</td><td class="fr">✅</td><td class="fd">MIDI note numbers — sorted, may be empty</td></tr>
            <tr><td class="fk">title</td><td class="ft">string</td><td class="fo">—</td><td class="fd">Human-readable session name</td></tr>
            <tr><td class="fk">author</td><td class="ft">string</td><td class="fo">—</td><td class="fd">Creator name</td></tr>
            <tr><td class="fk">created</td><td class="ft">string</td><td class="fo">—</td><td class="fd">ISO 8601 timestamp</td></tr>
            <tr><td class="fk">app</td><td class="ft">object</td><td class="fo">—</td><td class="fd">Originating app: name, version, url</td></tr>
            <tr><td class="fk">history</td><td class="ft">array</td><td class="fo">—</td><td class="fd">Reserved — session recording (v1.1)</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div style="margin-top:2rem;">
      <div class="slabel" style="margin-bottom:.5rem;">Valid Pitch Classes (state.root)</div>
      <div class="pitch-grid" id="pitch-grid"></div>
      <p style="font-size:.76rem;color:var(--muted);margin-top:.5rem;font-family:var(--fm);">Sharp notation canonical. Enharmonic flats not accepted (use C# not Db).</p>
    </div>
    <div style="margin-top:2rem;">
      <div class="slabel" style="margin-bottom:.5rem;">Valid Modes (state.mode)</div>
      <div class="modes-grid" id="modes-grid"></div>
    </div>
  </div>
</section>

<section id="validator">
  <div class="inner">
    <div class="slabel">Validator</div>
    <h2 class="stitle">Validate a .gcis File</h2>
    <p class="sdesc">Drop a file, paste JSON, or click a test case. Get a full diagnostic readout instantly.</p>
    <div class="vwrap">
      <div>
        <div class="vpanel">
          <div class="vhd">Input</div>
          <div class="vbody">
            <div class="dz" id="dz">
              <input type="file" accept=".gcis,application/json" id="fi" />
              <div style="font-size:1.4rem;margin-bottom:.3rem;">⬆</div>
              <div style="font-size:.8rem;color:var(--text2);"><strong style="color:var(--tl);">Drop .gcis file</strong> or click to browse</div>
            </div>
            <textarea id="ji" placeholder="Paste .gcis JSON here…&#10;(Cmd/Ctrl+Enter to validate)" spellcheck="false"></textarea>
            <button class="vbtn" id="vbtn">Validate</button>
            <button class="vclear" id="cbtn">Clear</button>
          </div>
        </div>
        <div class="vpanel" style="margin-top:1rem;">
          <div class="vhd">Built-in Tests <span id="tscore" style="margin-left:auto;font-size:.7rem;"></span></div>
          <div style="padding:.5rem;" id="tsuite"></div>
        </div>
      </div>
      <div class="vpanel" id="rpanel">
        <div class="vhd">Diagnostic Readout</div>
        <div id="rbody"><div class="rempty">Drop a .gcis file or paste JSON<br>to see the diagnostic readout.</div></div>
      </div>
    </div>
  </div>
</section>

<section id="downloads">
  <div class="inner">
    <div class="slabel">Downloads</div>
    <h2 class="stitle">Example .gcis Files</h2>
    <p class="sdesc">Download these to test your implementation or use as starting points. Each is a fully valid GCIS v1.0 document.</p>
    <div class="dl-grid" id="dlgrid"></div>
  </div>
</section>

<section id="implementors">
  <div class="inner">
    <div class="slabel">Implementors</div>
    <h2 class="stitle">Apps that speak GCIS</h2>
    <p class="sdesc">The reference implementation is the KCM Console. Want your app listed? Implement the spec, validate with the tool above, and get in touch.</p>
    <div style="display:flex;flex-direction:column;gap:.75rem;">
      <div class="icard">
        <div class="ilogo" style="background:rgba(0,128,128,.15);">🎵</div>
        <div>
          <div class="iname">KCM Console <span class="ibadge">Reference Implementation</span></div>
          <div class="idesc">Save and load .gcis from the Console header. Three panels — Music Theory Pro, Circle of Fifths, Modal Stencil — all sync from a single .gcis file. <a href="https://console.keyscodesandmodes.com">console.keyscodesandmodes.com ↗</a></div>
        </div>
      </div>
    </div>
    <div style="margin-top:1.5rem;padding:1.25rem;background:var(--elev);border:1px dashed rgba(0,128,128,.3);border-radius:12px;text-align:center;">
      <p style="color:var(--text2);font-size:.84rem;margin-bottom:.75rem;">Building a GCIS-compatible app?</p>
      <a href="mailto:ben@keyscodesandmodes.com?subject=GCIS Implementation" class="btn btn-o" style="font-size:.78rem;">Contact to get listed ↗</a>
    </div>
  </div>
</section>

<footer>
  <div class="nav-wheel" style="margin:0 auto .75rem;width:36px;height:36px;" aria-hidden="true"></div>
  <p><strong>GCIS — Global Chromatic Identity State</strong> · Version 1.0</p>
  <p>Created by <strong>Benjamin Ryan</strong> · <a href="https://keyscodesandmodes.com">Keys, Codes &amp; Modes™</a></p>
  <p>12-Color Chromatic Spectrum™ · FreeStyle® Musical Device (4 US Patents)</p>
  <p style="margin-top:.5rem;"><a href="https://console.keyscodesandmodes.com">KCM Console</a> · <a href="https://keyscodesandmodes.com">Main Site</a> · <a href="mailto:ben@keyscodesandmodes.com">Contact</a></p>
</footer>

<script>
'use strict';
const PITCH=['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
const MODES={ionian:{i:[0,2,4,5,7,9,11],a:'Major'},dorian:{i:[0,2,3,5,7,9,10],a:''},phrygian:{i:[0,1,3,5,7,8,10],a:''},lydian:{i:[0,2,4,6,7,9,11],a:''},mixolydian:{i:[0,2,4,5,7,9,10],a:'Dominant'},aeolian:{i:[0,2,3,5,7,8,10],a:'Natural Minor'},locrian:{i:[0,1,3,5,6,8,10],a:''}};
const COLORS={'C':'#FFFF00','C#':'#FFC400','D':'#FF8000','D#':'#FF4000','E':'#FF0000','F':'#C4007F','F#':'#8000FF','G':'#4000FF','G#':'#0000FF','A':'#007FFF','A#':'#00FF80','B':'#80FF00'};
const DARK=new Set(['C','C#','D','A#','B']);
const nc=n=>COLORS[n]||'#888', ink=n=>DARK.has(n)?'#000':'#fff';
const bn=(root,ivs)=>{const ri=PITCH.indexOf(root);return ri===-1?[]:ivs.map(iv=>PITCH[(ri+iv)%12]);};

/* Spec rendering */
document.getElementById('ex-json').innerHTML=`{
  <span class="k">"gcis"</span>:    <span class="s">"1.0"</span>,
  <span class="k">"created"</span>: <span class="s">"2026-04-25T14:30:00.000Z"</span>,
  <span class="k">"title"</span>:   <span class="s">"G Dorian — Session 1"</span>,
  <span class="k">"author"</span>:  <span class="s">"Benjamin Ryan"</span>,
  <span class="k">"app"</span>: {
    <span class="k">"name"</span>:    <span class="s">"KCM Console"</span>,
    <span class="k">"version"</span>: <span class="s">"0.8.0"</span>,
    <span class="k">"url"</span>:     <span class="s">"https://console.keyscodesandmodes.com"</span>
  },
  <span class="k">"state"</span>: {
    <span class="k">"root"</span>:        <span class="s">"G"</span>,
    <span class="k">"mode"</span>:        <span class="s">"dorian"</span>,
    <span class="k">"scale"</span>:       [<span class="n">0</span>,<span class="n">2</span>,<span class="n">3</span>,<span class="n">5</span>,<span class="n">7</span>,<span class="n">9</span>,<span class="n">10</span>],
    <span class="k">"activeNotes"</span>: [<span class="n">67</span>,<span class="n">71</span>,<span class="n">74</span>]
  },
  <span class="k">"history"</span>: []
}`;

const pg=document.getElementById('pitch-grid');
PITCH.forEach(n=>{pg.innerHTML+=`<div class="pdot" style="background:${nc(n)};color:${ink(n)}">${n}</div>`;});

const mg=document.getElementById('modes-grid');
Object.entries(MODES).forEach(([k,v])=>{mg.innerHTML+=`<div class="mcard"><div class="mn">${k}</div>${v.a?`<div class="ma">${v.a}</div>`:''}<div class="mi">[${v.i.join(', ')}]</div></div>`;});

/* Validator */
function validate(doc){
  const e=[],w=[];
  if(!doc||typeof doc!=='object') return{ok:false,e:['Not a valid JSON object'],w};
  if(!doc.gcis) e.push('Missing required field: gcis');
  else if(doc.gcis!=='1.0') w.push('gcis version "'+doc.gcis+'" — current is "1.0"');
  if(!doc.state){e.push('Missing required field: state');return{ok:false,e,w};}
  const s=doc.state;
  if(!s.root) e.push('Missing state.root');
  else if(!PITCH.includes(s.root)) e.push('Invalid state.root "'+s.root+'" — valid: '+PITCH.join(', '));
  if(!s.mode) e.push('Missing state.mode');
  else if(!MODES[s.mode]) e.push('Invalid state.mode "'+s.mode+'" — valid: '+Object.keys(MODES).join(', '));
  if(!Array.isArray(s.scale)) e.push('state.scale must be an array');
  else{
    if(s.scale.length!==7) w.push('state.scale has '+s.scale.length+' elements — expected 7');
    if(s.mode&&MODES[s.mode]&&JSON.stringify(s.scale)!==JSON.stringify(MODES[s.mode].i))
      w.push('scale mismatch for "'+s.mode+'" — expected ['+MODES[s.mode].i.join(',')+']');
  }
  if(!Array.isArray(s.activeNotes)) e.push('state.activeNotes must be an array');
  if(!doc.title) w.push('Optional field missing: title');
  if(!doc.author) w.push('Optional field missing: author');
  return{ok:e.length===0,e,w};
}

function renderResults(jsonStr){
  const body=document.getElementById('rbody');
  body.innerHTML='';
  let doc;
  try{doc=JSON.parse(jsonStr);}
  catch(err){body.innerHTML=`<div class="sbanner bad fi">✗ JSON Parse Error</div><div class="diag"><div class="eline">${err.message}</div></div>`;return;}
  const{ok,e,w}=validate(doc);const s=doc.state||{};
  body.innerHTML=`<div class="sbanner ${ok?'ok':'bad'} fi">${ok?'✓ Valid GCIS v1.0':'✗ Invalid — '+e.length+' error'+(e.length!==1?'s':'')}</div>`;
  if(e.length){let h='<div class="diag fi"><div class="dlabel">Errors</div>';e.forEach(x=>{h+=`<div class="eline">✗ ${x}</div>`;});h+='</div>';body.innerHTML+=h;}
  if(w.length){let h='<div class="diag fi"><div class="dlabel">Warnings</div>';w.forEach(x=>{h+=`<div class="wline">⚠ ${x}</div>`;});h+='</div>';body.innerHTML+=h;}
  let meta='<div class="diag fi"><div class="dlabel">Metadata</div>';
  [['gcis',doc.gcis||'—'],['title',doc.title||'—'],['author',doc.author||'—'],
   ['created',(doc.created||'—').replace('T',' ').replace(/\.\d+Z/,' UTC')],
   ['app',doc.app?doc.app.name+' v'+doc.app.version:'—']
  ].forEach(([k,v])=>{meta+=`<div class="kv2"><span class="kvk">${k}</span><span class="kvv">${v}</span></div>`;});
  meta+='</div>';body.innerHTML+=meta;
  if(s.root||s.mode){
    const rc=nc(s.root||''),ri=ink(s.root||'');
    let st='<div class="diag fi"><div class="dlabel">Harmonic State</div>';
    st+=`<div class="kv2"><span class="kvk">root</span><span class="kvv" style="display:flex;align-items:center;gap:5px;"><span style="width:22px;height:22px;border-radius:4px;background:${rc};color:${ri};display:inline-flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:.58rem;font-weight:700;">${s.root||'?'}</span>${s.root||'—'} ${PITCH.includes(s.root)?'✅':'❌'}</span></div>`;
    st+=`<div class="kv2"><span class="kvk">mode</span><span class="kvv">${s.mode||'—'} ${MODES[s.mode]?'✅':'❌'}</span></div>`;
    if(Array.isArray(s.scale)&&s.scale.length&&s.root&&PITCH.includes(s.root)){
      const notes=bn(s.root,s.scale);
      st+='<div style="margin-top:.45rem;"><div class="dlabel">Scale</div><div class="sbar">';
      notes.forEach(n=>{st+=`<div class="sn" style="background:${nc(n)};color:${ink(n)}">${n}</div>`;});
      st+='</div></div>';
    }
    st+=`<div class="kv2" style="margin-top:.35rem;"><span class="kvk">activeNotes</span><span class="kvv">${Array.isArray(s.activeNotes)?(s.activeNotes.length?s.activeNotes.join(', '):'empty ✅'):'❌'}</span></div>`;
    st+='</div>';body.innerHTML+=st;
  }
}

/* Tests */
const TESTS=[
  {name:'Valid — G Dorian',expect:true,j:{gcis:'1.0',title:'G Dorian',author:'Test',created:new Date().toISOString(),app:{name:'KCM Console',version:'0.8.0',url:''},state:{root:'G',mode:'dorian',scale:[0,2,3,5,7,9,10],activeNotes:[]},history:[]}},
  {name:'Valid — C Ionian + notes',expect:true,j:{gcis:'1.0',state:{root:'C',mode:'ionian',scale:[0,2,4,5,7,9,11],activeNotes:[60,64,67]}}},
  {name:'Valid — E♭ Lydian (D#)',expect:true,j:{gcis:'1.0',state:{root:'D#',mode:'lydian',scale:[0,2,4,6,7,9,11],activeNotes:[]}}},
  {name:'Invalid root — "H"',expect:false,j:{gcis:'1.0',state:{root:'H',mode:'ionian',scale:[0,2,4,5,7,9,11],activeNotes:[]}}},
  {name:'Invalid mode — "major"',expect:false,j:{gcis:'1.0',state:{root:'C',mode:'major',scale:[0,2,4,5,7,9,11],activeNotes:[]}}},
  {name:'Missing state field',expect:false,j:{gcis:'1.0',title:'No state'}},
  {name:'Corrupt JSON',expect:false,raw:'{ not valid json !!!'},
];
function runTests(){
  const suite=document.getElementById('tsuite');suite.innerHTML='';let passed=0;
  TESTS.forEach(t=>{
    const jstr=t.raw||JSON.stringify(t.j);
    let ok;try{ok=validate(JSON.parse(jstr)).ok;}catch(e){ok=false;}
    const pass=ok===t.expect;if(pass)passed++;
    const row=document.createElement('div');row.className='trow';
    row.innerHTML=`<span class="tname">${t.name}</span><span class="${pass?'tpass':'tfail'}">${pass?'✅ PASS':'❌ FAIL'}</span>`;
    row.onclick=()=>{document.getElementById('ji').value=t.raw||JSON.stringify(t.j,null,2);renderResults(jstr);document.getElementById('rpanel').scrollIntoView({behavior:'smooth'});};
    suite.appendChild(row);
  });
  const sum=document.createElement('div');sum.className='tsum';sum.style.color=passed===TESTS.length?'var(--green)':'var(--red)';sum.textContent=passed+' / '+TESTS.length+' passed';suite.appendChild(sum);
  const sc=document.getElementById('tscore');sc.textContent=passed+'/'+TESTS.length;sc.style.color=passed===TESTS.length?'var(--green)':'var(--red)';
}

/* Downloads */
const EXAMPLES=[
  {name:'C Ionian (Major)',root:'C',mode:'ionian',notes:[]},
  {name:'G Dorian',root:'G',mode:'dorian',notes:[67,69,71]},
  {name:'D Mixolydian',root:'D',mode:'mixolydian',notes:[]},
  {name:'A Aeolian (Minor)',root:'A',mode:'aeolian',notes:[69,72,76]},
  {name:'E Phrygian',root:'E',mode:'phrygian',notes:[]},
  {name:'F# Locrian',root:'F#',mode:'locrian',notes:[]},
];
const dlg=document.getElementById('dlgrid');
EXAMPLES.forEach(ex=>{
  const doc={gcis:'1.0',created:new Date().toISOString(),title:ex.name,author:'Benjamin Ryan',app:{name:'KCM Console',version:'0.8.0',url:'https://console.keyscodesandmodes.com'},state:{root:ex.root,mode:ex.mode,scale:MODES[ex.mode].i,activeNotes:ex.notes},history:[]};
  const notes=bn(ex.root,MODES[ex.mode].i);
  const card=document.createElement('div');card.className='dl-card';
  card.innerHTML=`<div class="dli">📄</div><div class="dln">${ex.name}</div><div style="display:flex;gap:3px;flex-wrap:wrap;">${notes.map(n=>`<span style="width:21px;height:21px;border-radius:4px;background:${nc(n)};color:${ink(n)};display:inline-flex;align-items:center;justify-content:center;font-size:.54rem;font-weight:700;font-family:var(--fd);">${n}</span>`).join('')}</div><div class="dlt">${ex.root} ${ex.mode} · .gcis</div>`;
  card.onclick=()=>{
    const blob=new Blob([JSON.stringify(doc,null,2)],{type:'application/json'});
    const url=URL.createObjectURL(blob);const a=document.createElement('a');
    a.href=url;a.download=ex.name.toLowerCase().replace(/[^a-z0-9]+/g,'-')+'.gcis';
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    setTimeout(()=>URL.revokeObjectURL(url),1000);
  };
  dlg.appendChild(card);
});

/* Wire UI */
document.getElementById('vbtn').addEventListener('click',()=>{const v=document.getElementById('ji').value.trim();if(!v){alert('Paste a .gcis JSON document first.');return;}renderResults(v);});
document.getElementById('cbtn').addEventListener('click',()=>{document.getElementById('ji').value='';document.getElementById('rbody').innerHTML='<div class="rempty">Drop a .gcis file or paste JSON<br>to see the diagnostic readout.</div>';});
document.getElementById('ji').addEventListener('keydown',e=>{if((e.metaKey||e.ctrlKey)&&e.key==='Enter')renderResults(e.target.value.trim());});
document.getElementById('fi').addEventListener('change',function(){const f=this.files[0];if(!f)return;const r=new FileReader();r.onload=e=>{document.getElementById('ji').value=e.target.result;renderResults(e.target.result);};r.readAsText(f);this.value='';});
const dz=document.getElementById('dz');
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('over');});
dz.addEventListener('dragleave',()=>dz.classList.remove('over'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('over');const f=e.dataTransfer.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{document.getElementById('ji').value=ev.target.result;renderResults(ev.target.result);};r.readAsText(f);});

runTests();
</script>
</body>
