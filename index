    .btn-o{background:transparent;color:var(--gold);border:1px solid rgba(244,208,63,.4);}
    .btn-o:hover{background:rgba(244,208,63,.08);border-color:var(--gold);color:var(--gold);}

    /* Sections */
    section{padding:4rem 2rem;}
    section:nth-child(even){background:var(--panel);}
    .inner{max-width:960px;margin:0 auto;}
    .slabel{font-family:var(--fm);font-size:.7rem;font-weight:500;color:var(--tl);letter-spacing:.18em;text-transform:uppercase;margin-bottom:.6rem;}
    .stitle{font-family:var(--fd);font-size:clamp(1.4rem,3.5vw,2.1rem);font-weight:700;color:var(--text);margin-bottom:1rem;line-height:1.2;}
    .sdesc{font-size:1rem;color:var(--text2);max-width:620px;line-height:1.75;margin-bottom:2.5rem;}

    /* Why grid */
    .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1rem;}
    .why-card{background:var(--elev);border:1px solid var(--border);border-radius:12px;padding:1.5rem;transition:all .2s;}
    .why-card:hover{border-color:rgba(0,128,128,.4);transform:translateY(-2px);}
    .wi{font-size:1.5rem;margin-bottom:.75rem;}
    .wt{font-family:var(--fd);font-size:.88rem;font-weight:600;color:var(--gold);margin-bottom:.4rem;}
    .wd{font-size:.82rem;color:var(--text2);line-height:1.65;}

    /* Spec */
    .spec-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
    @media(max-width:700px){.spec-grid{grid-template-columns:1fr;}}
    .spec-blk{background:var(--elev);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
    .spec-hd{padding:.65rem 1rem;background:rgba(0,128,128,.06);border-bottom:1px solid var(--border);font-family:var(--fm);font-size:.72rem;color:var(--tl);letter-spacing:.1em;}
    .spec-blk pre{padding:1rem;font-family:var(--fm);font-size:.76rem;color:var(--text2);line-height:1.7;overflow-x:auto;white-space:pre;}
    .k{color:var(--purple);} .s{color:var(--tl);} .n{color:var(--gold);} .c{color:var(--muted);font-style:italic;}
    .ftable{width:100%;border-collapse:collapse;font-size:.82rem;}
    .ftable th{text-align:left;padding:.55rem .7rem;font-family:var(--fm);font-size:.65rem;font-weight:500;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;border-bottom:1px solid var(--border);}
