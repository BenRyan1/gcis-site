    .ft{font-family:var(--fm);color:var(--purple);font-size:.72rem;}
    .fr{font-size:.7rem;color:var(--green);font-weight:600;}
    .fo{font-size:.7rem;color:var(--muted);}
    .fd{color:var(--text2);font-size:.8rem;}

    /* Pitch & modes */
    .pitch-grid{display:flex;flex-wrap:wrap;gap:6px;margin-top:.5rem;}
    .pdot{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:.66rem;font-weight:700;}
    .modes-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:.6rem;margin-top:.5rem;}
    .mcard{background:var(--elev);border:1px solid var(--border);border-radius:8px;padding:.7rem 1rem;}
    .mn{font-family:var(--fm);font-size:.8rem;color:var(--tl);margin-bottom:2px;}
    .ma{font-size:.7rem;color:var(--muted);margin-bottom:4px;}
    .mi{font-family:var(--fm);font-size:.68rem;color:var(--text2);}

    /* Validator */
    .vwrap{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:1.5rem;}
    @media(max-width:700px){.vwrap{grid-template-columns:1fr;}}
    .vpanel{background:var(--elev);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
    .vhd{padding:.65rem 1rem;background:rgba(0,128,128,.06);border-bottom:1px solid var(--border);font-family:var(--fm);font-size:.72rem;color:var(--tl);letter-spacing:.1em;display:flex;align-items:center;justify-content:space-between;}
    .vbody{padding:1rem;}
    .dz{border:2px dashed rgba(0,128,128,.3);border-radius:8px;padding:1.5rem 1rem;text-align:center;cursor:pointer;transition:all .2s;position:relative;margin-bottom:.75rem;}
    .dz:hover,.dz.over{border-color:var(--tl);background:rgba(0,128,128,.05);}
    .dz input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
    textarea{width:100%;min-height:170px;resize:vertical;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.7rem;font-family:var(--fm);font-size:.74rem;color:var(--tl);line-height:1.6;outline:none;transition:border-color .2s;}
    textarea:focus{border-color:var(--tl);}
    textarea::placeholder{color:var(--muted);}
    .vbtn{width:100%;margin-top:.6rem;padding:.62rem;background:linear-gradient(135deg,var(--teal),#005f5f);border:none;border-radius:8px;font-family:var(--fd);font-size:.78rem;font-weight:600;color:#fff;cursor:pointer;letter-spacing:.08em;text-transform:uppercase;transition:all .15s;}
