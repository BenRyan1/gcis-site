  <style>
    :root {
      --bg:#0a0a15; --panel:#0f0f1e; --elev:#141428;
      --teal:#008080; --tl:#00c0c0; --gold:#F4D03F;
      --purple:#8B6BA3; --coral:#CF7A5A; --green:#00e08a; --red:#ff4455;
      --text:#e8e8f8; --text2:#b0b0cc; --muted:#5a5a7a;
      --border:rgba(0,128,128,0.18);
      --fd:'Cinzel',serif; --fb:'Montserrat',sans-serif; --fm:'JetBrains Mono',monospace;
      --C:#FFFF00;--Cs:#FFC400;--D:#FF8000;--Ds:#FF4000;
      --E:#FF0000;--F:#C4007F;--Fs:#8000FF;--G:#4000FF;
      --Gs:#0000FF;--A:#007FFF;--As:#00FF80;--B:#80FF00;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--fb);background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;}
    a{color:var(--tl);text-decoration:none;transition:color .2s;}
    a:hover{color:var(--gold);}
    :focus-visible{outline:2px solid var(--gold);outline-offset:3px;}

    /* Nav */
    nav{position:sticky;top:0;z-index:100;background:rgba(10,10,21,.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:60px;gap:1rem;}
    .nav-brand{display:flex;align-items:center;gap:.75rem;font-family:var(--fd);font-size:1.05rem;font-weight:600;color:var(--text);letter-spacing:.04em;}
    .nav-wheel{width:32px;height:32px;border-radius:50%;flex-shrink:0;background:conic-gradient(from -15deg,var(--C) 0 30deg,var(--Cs) 30deg 60deg,var(--D) 60deg 90deg,var(--Ds) 90deg 120deg,var(--E) 120deg 150deg,var(--F) 150deg 180deg,var(--Fs) 180deg 210deg,var(--G) 210deg 240deg,var(--Gs) 240deg 270deg,var(--A) 270deg 300deg,var(--As) 300deg 330deg,var(--B) 330deg 360deg);box-shadow:0 0 0 2px var(--bg),0 0 0 3px var(--teal);}
    .nav-links{display:flex;gap:.25rem;}
    .nav-links a{padding:.4rem .9rem;border-radius:6px;font-size:.82rem;font-weight:500;color:var(--text2);transition:all .15s;}
    .nav-links a:hover{color:var(--tl);background:rgba(0,128,128,.08);}
    .nav-badge{font-family:var(--fm);font-size:.7rem;color:var(--tl);background:rgba(0,128,128,.12);border:1px solid rgba(0,128,128,.3);border-radius:4px;padding:.2rem .55rem;letter-spacing:.06em;}

    /* Chromatic strip */
    .chrom{display:flex;height:4px;}
    .chrom span{flex:1;}

    /* Hero */
    .hero{max-width:900px;margin:0 auto;padding:5rem 2rem 4rem;text-align:center;}
    .eyebrow{font-family:var(--fm);font-size:.75rem;color:var(--tl);letter-spacing:.18em;text-transform:uppercase;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:center;gap:.5rem;}
    .eyebrow::before,.eyebrow::after{content:'';flex:1;max-width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--teal));}
    .eyebrow::after{background:linear-gradient(90deg,var(--teal),transparent);}
    .hero h1{font-family:var(--fd);font-size:clamp(3rem,10vw,6rem);font-weight:900;letter-spacing:.06em;background:linear-gradient(135deg,var(--gold) 0%,var(--tl) 60%,var(--purple) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1.05;margin-bottom:.75rem;}
    .hero-sub{font-family:var(--fd);font-size:clamp(1rem,2.5vw,1.35rem);color:var(--text2);margin-bottom:2rem;letter-spacing:.03em;}
    .hero-desc{font-size:1rem;color:var(--text2);max-width:580px;margin:0 auto 2.5rem;line-height:1.8;}
    .hero-desc strong{color:var(--gold);}
    .cta{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;}
    .btn{padding:.72rem 1.6rem;border-radius:8px;font-family:var(--fb);font-size:.86rem;font-weight:600;cursor:pointer;transition:all .15s;letter-spacing:.04em;border:none;display:inline-flex;align-items:center;gap:.4rem;}
